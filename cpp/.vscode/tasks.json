{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "g++",
            "detail": "Task generated by Debugger.",
            "type": "shell",
            // 编译c++使用g++命令，gcc命令只能编译c
            "command": "/usr/bin/g++",
            "args": [
                "-std=c++11",
                // -g生成调试信息
                "-g",
                "${file}",
                // -o指定输出文件名
                "-o",
                "${fileDirname}/target/a.out"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "cmake",
            "detail": "Execute cmake . command",
            "type": "shell",
            "command": "/usr/bin/cmake",
            "args": [
                "."
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "label": "make",
            "detail": "Task generated by Debugger.",
            "type": "shell",
            "command": "/usr/bin/make",
            "args": [
                ""
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            // 依赖上面的cmake任务
            "dependsOn": [ "cmake" ],
            // 执行顺序是线性的
            "dependsOrder": "sequence"
        }
    ]
}